  "info": {
    "_postman_id": "1c7bb319-e5c8-4243-acea-ff25cca58f33",
    "name": "Kushki Cash Payments API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Generate cash-payment vouchers redeemable at LatAm correspondent and convenience-store\nnetworks — OXXO and 7-Eleven in Mexico, PagoEfectivo in Peru, Boleto in Brazil, and\nEcuadorean and Colombian correspondent networks. Returns a barcode/reference and\nan expiry date.\n\n\nContact Support:\n Name: Kushki\n Email: dev@kushkipagos.com",
      "type": "text/plain"
    }
